{
    "success": true,
    "objects": {
        "OrderItem": {
            "1001": {
                "id": 999,
                "order_item_id": 1001,
                "product": "Widget",
                "quantity": 2
            },
            "1002": {
                "id": 998,
                "order_item_id": 1002,
                "product": "Gadget",
                "quantity": 5
            }
        }
    },
    "records": [
        {
            "type": "OrderItem",
            "value": {
                "id": 999,
                "order_item_id": 1001,
                "product": "Widget",
                "quantity": 2
            }
        },
        {
            "type": "OrderItem",
            "value": {
                "id": 998,
                "order_item_id": 1002,
                "product": "Gadget",
                "quantity": 5
            }
        }
    ],
    "record_validations": [
        {
            "description": "first record id field is 999 (not the identifier)",
            "path": "#/records/0/value/id",
            "expected_value": 999
        },
        {
            "description": "first record order_item_id is 1001 (the identifier)",
            "path": "#/records/0/value/order_item_id",
            "expected_value": 1001
        },
        {
            "description": "second record id field is 998",
            "path": "#/records/1/value/id",
            "expected_value": 998
        },
        {
            "description": "second record order_item_id is 1002",
            "path": "#/records/1/value/order_item_id",
            "expected_value": 1002
        }
    ],
    "object_validations": [
        {
            "description": "registry is keyed by order_item_id 1001, not by id 999",
            "path": "#/objects/OrderItem/1001/product",
            "expected_value": "Widget"
        },
        {
            "description": "registry is keyed by order_item_id 1002",
            "path": "#/objects/OrderItem/1002/quantity",
            "expected_value": 5
        },
        {
            "description": "registry key 999 does not exist (id field is not the identifier)",
            "path": "#/objects/OrderItem/999",
            "expected_value": null
        }
    ],
    "schema_validations": [
        {
            "description": "OrderItem identifier field is order_item_id",
            "path": "#/schema/types/OI/identifierField",
            "expected_value": "order_item_id"
        }
    ]
}
