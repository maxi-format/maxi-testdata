            }
        }
    },
    "records": [
        {
            "type": "Order",
            "value": {
                "id": 100,
                "items": [
                    {
                        "id": 1,
                        "name": "Widget",
                        "price": 9.99
                    },
                    {
                        "id": 2,
                        "name": "Gadget",
                        "price": 19.99
